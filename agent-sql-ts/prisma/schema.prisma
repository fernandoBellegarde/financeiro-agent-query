generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cliente {
  // Chave Primária
  client_origin_id String      @id 
  nome             String
  email            String?     // O sinal de interrogação significa que é opcional
  dataContaAberta  DateTime

  // Isso aqui é exclusivo do Prisma! Diz que esse cliente tem uma lista de transações
  transacoes       Transacao[] 
  
  createdAt        DateTime    @default(now())
}

model Transacao {
  id               Int      @id @default(autoincrement())
  tipoTransacao    String   
  valor            Float
  
  // --- RELACIONAMENTO ---
  // 1. O campo físico no banco de dados que guarda o ID do cliente
  client_origin_id String
  
  // 2. A "ponte" do Prisma ensinando que esse campo aponta para a tabela Cliente
  cliente          Cliente  @relation(fields: [client_origin_id], references: [client_origin_id])

  authorizedAt     DateTime @default(now())
}